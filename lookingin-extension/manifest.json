{
  "manifest_version": 3,
  "name": "LookingIn",
  "version": "1.0.0",
  "description": "See who is tracking you in real time.",

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "webRequest",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ]
}